 location: 'Old Battery', time: 'Tomorrow morning', chapter: 1, sequence: 121, quote: ''}, {id: 'event/9b86589a', name: 'The narrator stated they would come to him at the Battery', category: 'COMMUNICATION_VERBAL', location: 'Battery', time: 'Early in the morning', chapter: 1, sequence: 122, quote: ''}, {id: 'event/25fbbfea', name: 'The man threatened with a curse', category: 'COMMUNICATION_VERBAL', location: 'Battery', time: 'Early in the morning', chapter: 1, sequence: 123, quote: ''}, {id: 'event/7c681227', name: 'The speaker reminded the listener of their undertaking and the young man', category: 'COMMUNICATION_VERBAL', location: 'Battery', time: 'Early in the morning', chapter: 1, sequence: 124, quote: ''}, {id: 'event/6198b35d', name: 'The speaker instructed the listener to go home', category: 'COMMUNICATION_VERBAL', location: 'Battery', time: 'Early in the morning', chapter: 1, sequence: 125, quote: ''}, {id: 'event/3f8d08cf', name: 'He glanced about him over the cold wet flat', category: 'OBSERVATION', location: 'Cold wet flat', time: 'Early in the morning', chapter: 1, sequence: 126, quote: ''}, {id: 'event/d8017c23', name: 'He expressed a wish to be a frog', category: 'INTERNAL_THOUGHT', location: 'Cold wet flat', time: 'Early in the morning', chapter: 1, sequence: 127, quote: ''}, {id: 'event/39a53f63', name: 'He expressed a wish to be an eel', category: 'INTERNAL_THOUGHT', location: 'Cold wet flat', time: 'Early in the morning', chapter: 1, sequence: 128, quote: ''}, {id: 'event/b46480e8', name: 'He hugged his shuddering body in both his arms', category: 'PHYSICAL_MOVEMENT', location: 'Cold wet flat', time: 'Early in the morning', chapter: 1, sequence: 129, quote: ''}, {id: 'event/fc8632c7', name: 'He limped towards the low church wall', category: 'PHYSICAL_MOVEMENT', location: 'Churchyard', time: 'Early in the morning', chapter: 1, sequence: 130, quote: ''}, {id: 'event/89d98361', name: 'I saw him go, picking his way among the nettles and brambles', category: 'OBSERVATION', location: 'Churchyard', time: 'Early in the morning', chapter: 1, sequence: 131, quote: ''}, {id: 'event/6109772b', name: 'He looked as if he were eluding the hands of the dead people', category: 'INTERNAL_THOUGHT', location: 'Churchyard', time: 'Early in the morning', chapter: 1, sequence: 132, quote: ''}, {id: 'event/5a8f7f6e', name: 'The dead people were stretching up cautiously out of their graves', category: 'INTERNAL_THOUGHT', location: 'Churchyard', time: 'Early in the morning', chapter: 1, sequence: 133, quote: ''}, {id: 'event/4d71e451', name: 'The dead people were trying to get a twist upon his ankle and pull him in', category: 'INTERNAL_THOUGHT', location: 'Churchyard', time: 'Early in the morning', chapter: 1, sequence: 134, quote: ''}, {id: 'event/d81b4abf', name: 'The man got over the low church wall', category: 'PHYSICAL_MOVEMENT', location: 'Church wall', time: 'Early in the morning', chapter: 1, sequence: 135, quote: ''}, {id: 'event/da8bfbe6', name: 'The man turned round to look for Pip', category: 'PHYSICAL_MOVEMENT', location: 'Church wall', time: 'Early in the morning', chapter: 1, sequence: 136, quote: ''}, {id: 'event/a35fdf1b', name: 'Pip set his face towards home', category: 'PHYSICAL_MOVEMENT', location: 'Church wall', time: 'Early in the morning', chapter: 1, sequence: 137, quote: ''}, {id: 'event/4a34407b', name: 'Pip made the best use of his legs', category: 'PHYSICAL_MOVEMENT', location: 'Church wall', time: 'Early in the morning', chapter: 1, sequence: 138, quote: ''}, {id: 'event/e2bf563f', name: 'Pip looked over his shoulder', category: 'PHYSICAL_MOVEMENT', location: 'Church wall', time: 'Early in the morning', chapter: 1, sequence: 139, quote: ''}, {id: 'event/89a71946', name: 'Pip saw the man going towards the river', category: 'OBSERVATION', location: 'River', time: 'Early in the morning', chapter: 1, sequence: 140, quote: ''}, {id: 'event/799ae52a', name: 'The man was hugging himself in both arms', category: 'STATE_CHANGE', location: 'River', time: 'Early in the morning', chapter: 1, sequence: 141, quote: ''}, {id: 'event/897abbb7', name: 'The man was picking his way with his sore feet among the great stones', category: 'PHYSICAL_MOVEMENT', location: 'Marshes', time: 'Early in the morning', chapter: 1, sequence: 142, quote: ''}, {id: 'event/98e77042', name: 'The narrator stopped to look after him', category: 'PHYSICAL_MOVEMENT', location: 'Marshes', time: 'Early in the morning', chapter: 1, sequence: 143, quote: ''}, {id: 'event/316cb0a8', name: 'The narrator observed the marshes as a long black horizontal line', category: 'OBSERVATION', location: 'Marshes', time: 'Early in the morning', chapter: 1, sequence: 144, quote: ''}, {id: 'event/2aee0161', name: 'The narrator observed the river as another horizontal line, not broad nor black', category: 'OBSERVATION', location: 'Marshes', time: 'Early in the morning', chapter: 1, sequence: 145, quote: ''}, {id: 'event/b08e9993', name: 'The narrator observed the sky as a row of long angry red lines and dense black lines intermixed', category: 'OBSERVATION', location: 'Marshes', time: 'Early in the morning', chapter: 1, sequence: 146, quote: ''}, {id: 'event/ba86bbba', name: 'The narrator faintly made out two black things standing upright', category: 'OBSERVATION', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 147, quote: ''}, {id: 'event/8a8e869a', name: 'The narrator observed the beacon, described as an ugly thing when near', category: 'OBSERVATION', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 148, quote: ''}, {id: 'event/ed10baf2', name: 'The narrator observed a gibbet with chains hanging to it', category: 'OBSERVATION', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 149, quote: ''}, {id: 'event/be06abc3', name: 'A man was limping towards the gibbet', category: 'PHYSICAL_MOVEMENT', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 150, quote: ''}, {id: 'event/bbd1515c', name: 'The narrator implied that the man was the pirate come to life', category: 'INTERNAL_THOUGHT', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 151, quote: ''}, {id: 'event/49df9004', name: 'The man was going back to hook himself up again', category: 'PHYSICAL_MOVEMENT', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 152, quote: ''}, {id: 'event/56ee9472', name: 'Pip felt a terrible turn when he thought about the horrible young man', category: 'EMOTIONAL_REACTION', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 153, quote: ''}, {id: 'event/baba2b8a', name: 'Pip observed the cattle lifting their heads to gaze after the horrible young man', category: 'OBSERVATION', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 154, quote: ''}, {id: 'event/ee4f6bab', name: 'Pip wondered whether the cattle thought about the horrible young man too', category: 'INTERNAL_THOUGHT', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 155, quote: ''}, {id: 'event/292a1cf0', name: 'Pip looked all around for the horrible young man', category: 'OBSERVATION', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 156, quote: ''}, {id: 'event/584f13ba', name: 'Pip felt frightened again', category: 'EMOTIONAL_REACTION', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 157, quote: ''}, {id: 'event/998c01f7', name: 'Pip ran home without stopping', category: 'PHYSICAL_MOVEMENT', location: 'Edge of the river', time: 'Early in the morning', chapter: 1, sequence: 158, quote: ''}] AS row
