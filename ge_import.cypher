// 1. CREATE EVENT NODES
CREATE (e0:Event {id: "event/d6942f55", name: "Pip identifies himself by a shortened name", eventType: "reflection/emotion", actionType: "identify", source_quote: "So, I called myself Pip, and came to be called Pip.", causeWeight: 1.0, confidence: 0.9, sequence: 0, chapter: 2, time: "", location: ""});
CREATE (e1:Event {id: "event/71357888", name: "Pip reflects on his family name and Christian name", eventType: "reflection/emotion", actionType: "reflect", source_quote: "My father’s family name being Pirrip, and my Christian name Philip, my infant tongue could make of both names nothing longer or more explicit than Pip.", causeWeight: 1.0, confidence: 0.8, sequence: 1, chapter: 2, time: "", location: ""});
CREATE (e2:Event {id: "event/6fd2d3d3", name: "Identify family name", eventType: "other", actionType: "give", source_quote: "I give Pirrip as my father’s family name, on the authority of his tombstone and my sister,—Mrs. Joe Gargery, who married the blacksmith.", causeWeight: 1.0, confidence: 0.9, sequence: 2, chapter: 2, time: "", location: ""});
CREATE (e3:Event {id: "event/d355313e", name: "Acknowledge absence of parents", eventType: "reflection/emotion", actionType: "acknowledge", source_quote: "As I never saw my father or my mother, and never saw any likeness of either of them (for their days were long before the days of photographs)", causeWeight: 1.0, confidence: 0.9, sequence: 3, chapter: 2, time: "", location: ""});
CREATE (e4:Event {id: "event/dd9c26e0", name: "Formulate first fancies about parents", eventType: "reflection/emotion", actionType: "derive", source_quote: "my first fancies regarding what they were like were unreasonably derived from their tombstones.", causeWeight: 1.0, confidence: 0.8, sequence: 4, chapter: 2, time: "", location: ""});
CREATE (e5:Event {id: "event/0f128c73", name: "Perceive shape of letters on father's tombstone", eventType: "perception/recognition", actionType: "perceive", source_quote: "The shape of the letters on my father’s, gave me an odd idea that he was a square, stout, dark man, with curly black hair.", causeWeight: 1.0, confidence: 0.8, sequence: 5, chapter: 2, time: "", location: ""});
CREATE (e6:Event {id: "event/58c4082b", name: "Pip draws a conclusion about his mother", eventType: "reflection/emotion", actionType: "draw", source_quote: "I drew a childish conclusion that my mother was freckled and sickly.", causeWeight: 1.0, confidence: 0.7, sequence: 6, chapter: 2, time: "", location: ""});
CREATE (e7:Event {id: "event/88d8e171", name: "Pip perceives the inscription", eventType: "perception/recognition", actionType: "perceive", source_quote: "From the character and turn of the inscription, “_Also Georgiana Wife of the Above_,”", causeWeight: 1.0, confidence: 0.6, sequence: 7, chapter: 2, time: "", location: ""});
CREATE (e8:Event {id: "event/d5e64246", name: "Pip perceives the stone lozenges", eventType: "perception/recognition", actionType: "perceive", source_quote: "To five little stone lozenges, each about a foot and a half long, which were arranged in a neat row beside their grave...", causeWeight: 1.0, confidence: 0.7, sequence: 8, chapter: 2, time: "", location: ""});
CREATE (e9:Event {id: "event/ca319493", name: "Pip reflects on his brothers' early death", eventType: "reflection/emotion", actionType: "reflect", source_quote: "...who gave up trying to get a living, exceedingly early in that universal struggle...", causeWeight: 1.0, confidence: 0.8, sequence: 9, chapter: 2, time: "", location: ""});
CREATE (e10:Event {id: "event/2844ae9f", name: "Pip holds a belief about his brothers", eventType: "reflection/emotion", actionType: "believe", source_quote: "I am indebted for a belief I religiously entertained that they had all been born on their backs with their hands in their trousers-pockets...", causeWeight: 1.0, confidence: 0.7, sequence: 10, chapter: 2, time: "", location: ""});
CREATE (e11:Event {id: "event/cd3412bf", name: "Pip describes his brothers' state of existence", eventType: "reflection/emotion", actionType: "describe", source_quote: "...and had never taken them out in this state of existence.", causeWeight: 1.0, confidence: 0.6, sequence: 11, chapter: 2, time: "", location: ""});
CREATE (e12:Event {id: "event/2a25e045", name: "Pip perceives the marsh country", eventType: "perception/recognition", actionType: "perceive", source_quote: "Ours was the marsh country, down by the river, within, as the river wound, twenty miles of the sea.", causeWeight: 1.0, confidence: 0.9, sequence: 12, chapter: 2, time: "afternoon towards evening", location: "marsh country"});
CREATE (e13:Event {id: "event/f90effe7", name: "Pip reflects on his impression", eventType: "reflection/emotion", actionType: "reflect", source_quote: "My first most vivid and broad impression of the identity of things seems to me to have been gained on a memorable raw afternoon towards evening.", causeWeight: 1.0, confidence: 0.8, sequence: 13, chapter: 2, time: "", location: "marsh country"});
CREATE (e14:Event {id: "event/bcf5b04e", name: "Pip recognizes the churchyard", eventType: "perception/recognition", actionType: "recognize", source_quote: "I found out for certain that this bleak place overgrown with nettles was the churchyard", causeWeight: 1.0, confidence: 0.9, sequence: 14, chapter: 2, time: "", location: "churchyard"});
CREATE (e15:Event {id: "event/400969cb", name: "Pip learns about the deceased", eventType: "perception/recognition", actionType: "learn", source_quote: "that Philip Pirrip, late of this parish, and also Georgiana wife of the above, were dead and buried", causeWeight: 1.0, confidence: 0.8, sequence: 15, chapter: 2, time: "", location: "churchyard"});
CREATE (e16:Event {id: "event/09fbf03d", name: "Pip learns about the infant children", eventType: "perception/recognition", actionType: "learn", source_quote: "that Alexander, Bartholomew, Abraham, Tobias, and Roger, infant children of the aforesaid, were also dead and buried", causeWeight: 1.0, confidence: 0.8, sequence: 16, chapter: 2, time: "", location: "churchyard"});
CREATE (e17:Event {id: "event/b843dd0d", name: "Pip perceives the marshes", eventType: "perception/recognition", actionType: "perceive", source_quote: "the dark flat wilderness beyond the churchyard, intersected with dikes and mounds and gates, with scattered cattle feeding on it, was the marshes", causeWeight: 1.0, confidence: 0.7, sequence: 17, chapter: 2, time: "", location: "marshes"});
CREATE (e18:Event {id: "event/450382e4", name: "Pip perceives the river", eventType: "perception/recognition", actionType: "perceive", source_quote: "the low leaden line beyond was the river", causeWeight: 1.0, confidence: 0.7, sequence: 18, chapter: 2, time: "", location: "marshes"});
CREATE (e19:Event {id: "event/b1a5d609", name: "Pip perceives the sea", eventType: "perception/recognition", actionType: "perceive", source_quote: "the distant savage lair from which the wind was rushing was the sea", causeWeight: 1.0, confidence: 0.7, sequence: 19, chapter: 2, time: "", location: "marshes"});
CREATE (e20:Event {id: "event/7d910fc4", name: "Pip feels afraid", eventType: "reflection/emotion", actionType: "feel", source_quote: "the small bundle of shivers growing afraid of it all", causeWeight: 1.0, confidence: 0.9, sequence: 20, chapter: 2, time: "", location: "marshes"});
CREATE (e21:Event {id: "event/47c9eb8f", name: "Pip begins to cry", eventType: "action", actionType: "fear", source_quote: "beginning to cry", causeWeight: 1.0, confidence: 0.9, sequence: 21, chapter: 2, time: "", location: "marshes"});
CREATE (e22:Event {id: "event/a074f3e7", name: "A man starts up from among the graves", eventType: "movement/departure", actionType: "start", source_quote: "as a man started up from among the graves at the side of the church porch.", causeWeight: 1.0, confidence: 0.7, sequence: 22, chapter: 2, time: "", location: "church porch"});
CREATE (e23:Event {id: "event/ca08d766", name: "A man cries out to keep quiet", eventType: "encounter/dialogue", actionType: "fear", source_quote: "“Hold your noise!” cried a terrible voice,", causeWeight: 1.0, confidence: 0.9, sequence: 23, chapter: 2, time: "", location: "church porch"});
CREATE (e24:Event {id: "event/7404b1ce", name: "A man threatens to cut a throat", eventType: "conflict/threat", actionType: "threaten", source_quote: "or I’ll cut your throat!", causeWeight: 1.0, confidence: 0.9, sequence: 24, chapter: 2, time: "", location: "church porch"});
CREATE (e25:Event {id: "event/fce79bbc", name: "A man addresses a little devil", eventType: "encounter/dialogue", actionType: "address", source_quote: "Keep still, you little devil,", causeWeight: 1.0, confidence: 0.8, sequence: 25, chapter: 2, time: "", location: "church porch"});
CREATE (e26:Event {id: "event/ce3203ba", name: "Man appears", eventType: "perception/recognition", actionType: "appear", source_quote: "A fearful man, all in coarse grey, with a great iron on his leg.", causeWeight: 1.0, confidence: 0.7, sequence: 26, chapter: 2, time: "", location: "church porch"});
CREATE (e27:Event {id: "event/02470252", name: "Man is described", eventType: "reflection/emotion", actionType: "describe", source_quote: "A man with no hat, and with broken shoes, and with an old rag tied round his head.", causeWeight: 1.0, confidence: 0.6, sequence: 27, chapter: 2, time: "", location: "church porch"});
CREATE (e28:Event {id: "event/d36d72ee", name: "Man's condition detailed", eventType: "reflection/emotion", actionType: "detail", source_quote: "A man who had been soaked in water, and smothered in mud, and lamed by stones, and cut by flints, and stung by nettles, and torn by briars.", causeWeight: 1.0, confidence: 0.6, sequence: 28, chapter: 2, time: "", location: "church porch"});
CREATE (e29:Event {id: "event/24ae454d", name: "Man exhibits physical symptoms", eventType: "reflection/emotion", actionType: "exhibit", source_quote: "who limped, and shivered, and glared, and growled; and whose teeth chattered in his head.", causeWeight: 1.0, confidence: 0.6, sequence: 29, chapter: 2, time: "", location: "church porch"});
CREATE (e30:Event {id: "event/bb8f6c41", name: "Man seizes Pip", eventType: "action", actionType: "seize", source_quote: "as he seized me by the chin.", causeWeight: 1.0, confidence: 0.8, sequence: 30, chapter: 2, time: "", location: "church porch"});
CREATE (e31:Event {id: "event/b7572215", name: "Pip pleads for his life", eventType: "encounter/dialogue", actionType: "plead", source_quote: "Oh! Don’t cut my throat, sir,” I pleaded in terror.", causeWeight: 1.0, confidence: 0.9, sequence: 31, chapter: 2, time: "", location: "church porch"});
CREATE (e32:Event {id: "event/42c5872b", name: "Pip expresses terror", eventType: "reflection/emotion", actionType: "feel", source_quote: "I pleaded in terror.", causeWeight: 1.0, confidence: 0.9, sequence: 32, chapter: 2, time: "", location: "church porch"});
CREATE (e33:Event {id: "event/ebf60c1f", name: "Pip prays for mercy", eventType: "encounter/dialogue", actionType: "pray", source_quote: "Pray don’t do it, sir.", causeWeight: 1.0, confidence: 0.9, sequence: 33, chapter: 2, time: "", location: "church porch"});
CREATE (e34:Event {id: "event/2e49dd2b", name: "Man stares at Pip", eventType: "perception/recognition", actionType: "stare", source_quote: "Once more,” said the man, staring at me.", causeWeight: 1.0, confidence: 0.7, sequence: 34, chapter: 2, time: "", location: "church porch"});
CREATE (e35:Event {id: "event/ccf0a206", name: "Man commands Pip to give it mouth", eventType: "encounter/dialogue", actionType: "command", source_quote: "Give it mouth!", causeWeight: 1.0, confidence: 0.8, sequence: 35, chapter: 2, time: "", location: "church porch"});
CREATE (e36:Event {id: "event/ed063162", name: "Man requests location", eventType: "encounter/dialogue", actionType: "request", source_quote: "Show us where you live,” said the man.", causeWeight: 1.0, confidence: 0.7, sequence: 36, chapter: 2, time: "", location: "church porch"});
CREATE (e37:Event {id: "event/04521611", name: "Man demands specific location", eventType: "encounter/dialogue", actionType: "demand", source_quote: "Pint out the place!", causeWeight: 1.0, confidence: 0.7, sequence: 37, chapter: 2, time: "", location: "church porch"});
CREATE (e38:Event {id: "event/b5a9d2cf", name: "Pip points to the village", eventType: "action", actionType: "point", source_quote: "I pointed to where our village lay", causeWeight: 1.0, confidence: 0.8, sequence: 38, chapter: 2, time: "", location: "church porch"});
CREATE (e39:Event {id: "event/384ab265", name: "Pip describes the location of the village", eventType: "perception/recognition", actionType: "describe", source_quote: "where our village lay, on the flat in-shore among the alder-trees and pollards", causeWeight: 1.0, confidence: 0.7, sequence: 39, chapter: 2, time: "", location: "the flat in-shore among the alder-trees and pollards"});
CREATE (e40:Event {id: "event/acdf1572", name: "Pip indicates the distance to the church", eventType: "perception/recognition", actionType: "indicate", source_quote: "a mile or more from the church", causeWeight: 1.0, confidence: 0.6, sequence: 40, chapter: 2, time: "", location: "the flat in-shore among the alder-trees and pollards"});
CREATE (e41:Event {id: "event/dc39c907", name: "Man looks at Pip", eventType: "perception/recognition", actionType: "watch", source_quote: "The man, after looking at me for a moment,", causeWeight: 1.0, confidence: 0.8, sequence: 41, chapter: 2, time: "", location: "the flat in-shore among the alder-trees and pollards"});
CREATE (e42:Event {id: "event/f6f7de8a", name: "Man turns Pip upside down", eventType: "action", actionType: "turn", source_quote: "turned me upside down,", causeWeight: 1.0, confidence: 0.9, sequence: 42, chapter: 2, time: "", location: "the flat in-shore among the alder-trees and pollards"});
CREATE (e43:Event {id: "event/494f12cd", name: "Man empties Pip's pockets", eventType: "action", actionType: "empty", source_quote: "and emptied my pockets.", causeWeight: 1.0, confidence: 0.9, sequence: 43, chapter: 2, time: "", location: "the flat in-shore among the alder-trees and pollards"});
CREATE (e44:Event {id: "event/d28e2f57", name: "Pip finds nothing in pockets", eventType: "reflection/emotion", actionType: "discover", source_quote: "There was nothing in them but a piece of bread.", causeWeight: 1.0, confidence: 0.7, sequence: 44, chapter: 2, time: "", location: "the flat in-shore among the alder-trees and pollards"});
CREATE (e45:Event {id: "event/0a920a1e", name: "Church comes to itself", eventType: "movement/departure", actionType: "recover", source_quote: "When the church came to itself,", causeWeight: 1.0, confidence: 0.6, sequence: 45, chapter: 2, time: "", location: "church"});
CREATE (e46:Event {id: "event/b749d876", name: "Pip sees the steeple under his feet", eventType: "perception/recognition", actionType: "perceive", source_quote: "I saw the steeple under my feet,", causeWeight: 1.0, confidence: 0.7, sequence: 46, chapter: 2, time: "", location: "church"});
CREATE (e47:Event {id: "event/be94e2ee", name: "Pip is seated on a high tombstone", eventType: "action", actionType: "sit", source_quote: "I was seated on a high tombstone,", causeWeight: 1.0, confidence: 0.8, sequence: 47, chapter: 2, time: "", location: "high tombstone"});
CREATE (e48:Event {id: "event/800cd1e9", name: "Pip trembles", eventType: "reflection/emotion", actionType: "fear", source_quote: "trembling while he ate the bread ravenously.", causeWeight: 1.0, confidence: 0.9, sequence: 48, chapter: 2, time: "", location: "high tombstone"});
CREATE (e49:Event {id: "event/3d91cdba", name: "Man eats the bread ravenously", eventType: "action", actionType: "eat", source_quote: "while he ate the bread ravenously.", causeWeight: 1.0, confidence: 0.9, sequence: 49, chapter: 2, time: "", location: "high tombstone"});
CREATE (e50:Event {id: "event/fd9b8d4f", name: "Man comments on Pip's appearance", eventType: "encounter/dialogue", actionType: "comment", source_quote: "You young dog,” said the man, licking his lips, “what fat cheeks you ha’ got.", causeWeight: 1.0, confidence: 0.9, sequence: 50, chapter: 2, time: "", location: "high tombstone"});
CREATE (e51:Event {id: "event/e26baea0", name: "Pip perceives the size of others", eventType: "perception/recognition", actionType: "believe", source_quote: "I believe they were fat", causeWeight: 1.0, confidence: 0.6, sequence: 51, chapter: 2, time: "at that time", location: "high tombstone"});
CREATE (e52:Event {id: "event/7430971b", name: "Pip reflects on his own size and strength", eventType: "reflection/emotion", actionType: "reflect", source_quote: "though I was at that time undersized for my years, and not strong", causeWeight: 1.0, confidence: 0.6, sequence: 52, chapter: 2, time: "at that time", location: "high tombstone"});
CREATE (e53:Event {id: "event/22033131", name: "Man expresses desire to eat", eventType: "conflict/threat", actionType: "express", source_quote: "Darn me if I couldn’t eat ’em,", causeWeight: 1.0, confidence: 0.7, sequence: 53, chapter: 2, time: "", location: "high tombstone"});
CREATE (e54:Event {id: "event/ccddc861", name: "Man shakes head threateningly", eventType: "action", actionType: "shake", source_quote: "with a threatening shake of his head,", causeWeight: 1.0, confidence: 0.6, sequence: 54, chapter: 2, time: "", location: "high tombstone"});
CREATE (e55:Event {id: "event/6dde1a71", name: "Man contemplates eating", eventType: "reflection/emotion", actionType: "contemplate", source_quote: "and if I han’t half a mind to’t!", causeWeight: 1.0, confidence: 0.5, sequence: 55, chapter: 2, time: "", location: "high tombstone"});
CREATE (e56:Event {id: "event/7329b643", name: "Pip expresses hope", eventType: "reflection/emotion", actionType: "express", source_quote: "I earnestly expressed my hope that he wouldn’t", causeWeight: 1.0, confidence: 0.7, sequence: 56, chapter: 2, time: "", location: "high tombstone"});
CREATE (e57:Event {id: "event/c1eecfe7", name: "Pip holds tighter to the tombstone", eventType: "action", actionType: "hold", source_quote: "held tighter to the tombstone on which he had put me", causeWeight: 1.0, confidence: 0.8, sequence: 57, chapter: 2, time: "", location: "high tombstone"});
CREATE (e58:Event {id: "event/3c804823", name: "Pip tries to avoid crying", eventType: "reflection/emotion", actionType: "try", source_quote: "partly, to keep myself from crying", causeWeight: 1.0, confidence: 0.7, sequence: 58, chapter: 2, time: "", location: "high tombstone"});
CREATE (e59:Event {id: "event/f315960c", name: "Man asks about Pip's mother", eventType: "encounter/dialogue", actionType: "demand", source_quote: "“Now lookee here!” said the man. “Where’s your mother?”", causeWeight: 1.0, confidence: 0.7, sequence: 59, chapter: 2, time: "", location: "high tombstone"});
CREATE (e60:Event {id: "event/80560a58", name: "Pip starts running", eventType: "movement/departure", actionType: "start", source_quote: "He started, made a short run", causeWeight: 1.0, confidence: 0.8, sequence: 60, chapter: 2, time: "", location: "high tombstone"});
CREATE (e61:Event {id: "event/b4bd55d6", name: "Pip stops running", eventType: "movement/departure", actionType: "stop", source_quote: "and stopped", causeWeight: 1.0, confidence: 0.8, sequence: 61, chapter: 2, time: "", location: "high tombstone"});
CREATE (e62:Event {id: "event/f28648f6", name: "Pip looks over his shoulder", eventType: "perception/recognition", actionType: "watch", source_quote: "and looked over his shoulder", causeWeight: 1.0, confidence: 0.8, sequence: 62, chapter: 2, time: "", location: "high tombstone"});
CREATE (e63:Event {id: "event/3d73baf6", name: "Pip explains his relationship to Georgiana", eventType: "encounter/dialogue", actionType: "explain", source_quote: "There, sir!” I timidly explained.", causeWeight: 1.0, confidence: 0.8, sequence: 63, chapter: 2, time: "", location: "high tombstone"});
CREATE (e64:Event {id: "event/2b454d74", name: "Pip identifies Georgiana as his mother", eventType: "perception/recognition", actionType: "identify", source_quote: "Also Georgiana. That’s my mother.", causeWeight: 1.0, confidence: 0.7, sequence: 64, chapter: 2, time: "", location: "high tombstone"});
CREATE (e65:Event {id: "event/7f17058d", name: "Pip expresses surprise", eventType: "reflection/emotion", actionType: "exclaim", source_quote: "Oh!", causeWeight: 1.0, confidence: 0.9, sequence: 65, chapter: 2, time: "", location: "high tombstone"});
CREATE (e66:Event {id: "event/f7e949bf", name: "Pip asks about family", eventType: "encounter/dialogue", actionType: "demand", source_quote: "And is that your father alonger your mother?", causeWeight: 1.0, confidence: 0.8, sequence: 66, chapter: 2, time: "", location: "high tombstone"});
CREATE (e67:Event {id: "event/4bfd496f", name: "Pip returns", eventType: "movement/departure", actionType: "return", source_quote: "said he, coming back.", causeWeight: 1.0, confidence: 0.7, sequence: 67, chapter: 2, time: "", location: "high tombstone"});
CREATE (e68:Event {id: "event/8e34252a", name: "Pip acknowledges the presence of another person", eventType: "encounter/dialogue", actionType: "acknowledge", source_quote: "Yes, sir,” said I; “him too; late of this parish.", causeWeight: 1.0, confidence: 0.9, sequence: 68, chapter: 2, time: "", location: "high tombstone"});
CREATE (e69:Event {id: "event/5e1e74e8", name: "Pip is questioned about his living situation", eventType: "encounter/dialogue", actionType: "question", source_quote: "“Who d’ye live with,—supposin’ you’re kindly let to live, which I han’t made up my mind about?”", causeWeight: 1.0, confidence: 0.9, sequence: 69, chapter: 2, time: "", location: "high tombstone"});
CREATE (e70:Event {id: "event/cb0a2ae1", name: "Magwitch considers his decision about Pip's fate", eventType: "reflection/emotion", actionType: "consider", source_quote: "he muttered then, considering.", causeWeight: 1.0, confidence: 0.8, sequence: 70, chapter: 2, time: "", location: "high tombstone"});
CREATE (e71:Event {id: "event/f3dc4a74", name: "Introduction of Mrs. Joe Gargery", eventType: "other", actionType: "introduce", source_quote: "My sister, sir,—Mrs. Joe Gargery,—wife of Joe Gargery, the blacksmith, sir.", causeWeight: 1.0, confidence: 0.9, sequence: 71, chapter: 2, time: "", location: "high tombstone"});
CREATE (e72:Event {id: "event/fdd1fca7", name: "Magwitch speaks to Pip", eventType: "encounter/dialogue", actionType: "speak", source_quote: "“Blacksmith, eh?” said he.", causeWeight: 1.0, confidence: 0.8, sequence: 72, chapter: 2, time: "", location: "high tombstone"});
CREATE (e73:Event {id: "event/b03a14e6", name: "Magwitch looks at his leg", eventType: "perception/recognition", actionType: "watch", source_quote: "And looked down at his leg.", causeWeight: 1.0, confidence: 0.7, sequence: 73, chapter: 2, time: "", location: "high tombstone"});
CREATE (e74:Event {id: "event/7ba0e780", name: "Magwitch looks at Pip's leg and him", eventType: "perception/recognition", actionType: "watch", source_quote: "After darkly looking at his leg and me several times", causeWeight: 1.0, confidence: 0.8, sequence: 74, chapter: 2, time: "", location: "high tombstone"});
CREATE (e75:Event {id: "event/177fddeb", name: "Magwitch approaches Pip's tombstone", eventType: "movement/departure", actionType: "come closer", source_quote: "he came closer to my tombstone", causeWeight: 1.0, confidence: 0.7, sequence: 75, chapter: 2, time: "", location: "tombstone"});
CREATE (e76:Event {id: "event/b0003108", name: "Magwitch takes Pip by both arms", eventType: "action", actionType: "take", source_quote: "took me by both arms", causeWeight: 1.0, confidence: 0.9, sequence: 76, chapter: 2, time: "", location: "tombstone"});
CREATE (e77:Event {id: "event/5ef63070", name: "Magwitch tilts Pip back", eventType: "action", actionType: "tilt", source_quote: "tilted me back as far as he could hold me", causeWeight: 1.0, confidence: 0.8, sequence: 77, chapter: 2, time: "", location: "tombstone"});
CREATE (e78:Event {id: "event/dff08ed3", name: "Magwitch looks powerfully into Pip's eyes", eventType: "perception/recognition", actionType: "watch", source_quote: "his eyes looked most powerfully down into mine", causeWeight: 1.0, confidence: 0.9, sequence: 78, chapter: 2, time: "", location: "tombstone"});
CREATE (e79:Event {id: "event/7e800e01", name: "Pip looks helplessly up into Magwitch's eyes", eventType: "perception/recognition", actionType: "watch", source_quote: "and mine looked most helplessly up into his", causeWeight: 1.0, confidence: 0.8, sequence: 79, chapter: 2, time: "", location: "tombstone"});
CREATE (e80:Event {id: "event/22c61701", name: "Magwitch questions Pip about living", eventType: "encounter/dialogue", actionType: "question", source_quote: "Now lookee here,” he said, “the question being whether you’re to be let to live.", causeWeight: 1.0, confidence: 0.7, sequence: 80, chapter: 2, time: "", location: "tombstone"});
CREATE (e81:Event {id: "event/6a3eebb0", name: "Magwitch asks about a file", eventType: "encounter/dialogue", actionType: "demand", source_quote: "You know what a file is?", causeWeight: 1.0, confidence: 0.6, sequence: 81, chapter: 2, time: "", location: "tombstone"});
CREATE (e82:Event {id: "event/14e68cdd", name: "Pip feels helplessness", eventType: "reflection/emotion", actionType: "feel", source_quote: "so as to give me a greater sense of helplessness", causeWeight: 1.0, confidence: 0.8, sequence: 82, chapter: 2, time: "", location: "tombstone"});
CREATE (e83:Event {id: "event/b8d32c99", name: "Pip perceives danger", eventType: "perception/recognition", actionType: "perceive", source_quote: "so as to give me a greater sense of helplessness and danger", causeWeight: 1.0, confidence: 0.8, sequence: 83, chapter: 2, time: "", location: "tombstone"});
CREATE (e84:Event {id: "event/c5cce3bf", name: "Magwitch tilts Pip", eventType: "action", actionType: "tilt", source_quote: "After each question he tilted me over a little more", causeWeight: 1.0, confidence: 0.9, sequence: 84, chapter: 2, time: "", location: "tombstone"});
CREATE (e85:Event {id: "event/0f56388d", name: "Request for a file", eventType: "assistance/exchange", actionType: "request", source_quote: "You get me a file.", causeWeight: 1.0, confidence: 0.8, sequence: 85, chapter: 2, time: "", location: "tombstone"});
CREATE (e86:Event {id: "event/baf3c3ea", name: "Request for wittles", eventType: "assistance/exchange", actionType: "request", source_quote: "And you get me wittles.", causeWeight: 1.0, confidence: 0.8, sequence: 86, chapter: 2, time: "", location: "tombstone"});
CREATE (e87:Event {id: "event/67f6f073", name: "Threat of violence", eventType: "conflict/threat", actionType: "threaten", source_quote: "Or I’ll have your heart and liver out.", causeWeight: 1.0, confidence: 0.9, sequence: 87, chapter: 2, time: "", location: "tombstone"});
CREATE (e88:Event {id: "event/6ffa6909", name: "Repeated tilting", eventType: "action", actionType: "tilt", source_quote: "He tilted me again.", causeWeight: 1.0, confidence: 0.7, sequence: 88, chapter: 2, time: "", location: "tombstone"});
CREATE (e89:Event {id: "event/ffdb8b07", name: "Pip feels frightened", eventType: "reflection/emotion", actionType: "feel", source_quote: "I was dreadfully frightened", causeWeight: 1.0, confidence: 0.9, sequence: 89, chapter: 2, time: "", location: "tombstone"});
CREATE (e90:Event {id: "event/56c464c0", name: "Pip feels giddy", eventType: "reflection/emotion", actionType: "feel", source_quote: "and so giddy", causeWeight: 1.0, confidence: 0.8, sequence: 90, chapter: 2, time: "", location: "tombstone"});
CREATE (e91:Event {id: "event/03993360", name: "Pip clings to Magwitch", eventType: "action", actionType: "cling", source_quote: "I clung to him with both hands", causeWeight: 1.0, confidence: 0.9, sequence: 91, chapter: 2, time: "", location: "tombstone"});
CREATE (e92:Event {id: "event/a44ba170", name: "Pip requests assistance from Magwitch", eventType: "encounter/dialogue", actionType: "request", source_quote: "and said, 'If you would kindly please to let me keep upright, sir'", causeWeight: 1.0, confidence: 0.9, sequence: 92, chapter: 2, time: "", location: "tombstone"});
CREATE (e93:Event {id: "event/ff6c9b7d", name: "Pip expresses hope to not be sick", eventType: "reflection/emotion", actionType: "express", source_quote: "perhaps I shouldn’t be sick", causeWeight: 1.0, confidence: 0.8, sequence: 93, chapter: 2, time: "", location: "tombstone"});
CREATE (e94:Event {id: "event/bf1c45e7", name: "Pip expresses hope to attend more", eventType: "reflection/emotion", actionType: "express", source_quote: "and perhaps I could attend more", causeWeight: 1.0, confidence: 0.8, sequence: 94, chapter: 2, time: "", location: "tombstone"});
CREATE (e95:Event {id: "event/ca78f10d", name: "Pip experiences a tremendous dip and roll", eventType: "action", actionType: "experience", source_quote: "He gave me a most tremendous dip and roll", causeWeight: 1.0, confidence: 0.8, sequence: 95, chapter: 2, time: "", location: "church"});
CREATE (e96:Event {id: "event/c8ae6c23", name: "The church jumps over its own weathercock", eventType: "perception/recognition", actionType: "perceive", source_quote: "so that the church jumped over its own weathercock", causeWeight: 1.0, confidence: 0.6, sequence: 96, chapter: 2, time: "", location: "church"});
CREATE (e97:Event {id: "event/2dfebcc5", name: "He holds Pip by the arms", eventType: "action", actionType: "hold", source_quote: "Then, he held me by the arms", causeWeight: 1.0, confidence: 0.9, sequence: 97, chapter: 2, time: "", location: "null"});
CREATE (e98:Event {id: "event/1dfccc4e", name: "Pip is in an upright position on the top of the stone", eventType: "state change", actionType: "be", source_quote: "in an upright position on the top of the stone", causeWeight: 1.0, confidence: 0.7, sequence: 98, chapter: 2, time: "", location: "null"});
CREATE (e99:Event {id: "event/73298ec4", name: "Magwitch speaks in fearful terms", eventType: "encounter/dialogue", actionType: "speak", source_quote: "went on in these fearful terms", causeWeight: 1.0, confidence: 0.8, sequence: 99, chapter: 2, time: "", location: "null"});
CREATE (e100:Event {id: "event/595975b5", name: "Magwitch demands items from Pip", eventType: "encounter/dialogue", actionType: "demand", source_quote: "You bring me, to-morrow morning early, that file and them wittles.", causeWeight: 1.0, confidence: 0.9, sequence: 100, chapter: 2, time: "tomorrow morning early", location: "the old Battery"});
CREATE (e101:Event {id: "event/fd23e7ef", name: "Magwitch threatens Pip", eventType: "conflict/threat", actionType: "threaten", source_quote: "You fail, or you go from my words in any partickler, no matter how small it is, and your heart and your liver shall be tore out, roasted, and ate.", causeWeight: 1.0, confidence: 0.9, sequence: 101, chapter: 2, time: "", location: "the old Battery"});
CREATE (e102:Event {id: "event/3f262f97", name: "Magwitch reveals he is not alone", eventType: "perception/recognition", actionType: "reveal", source_quote: "Now, I ain’t alone, as you may think I am.", causeWeight: 1.0, confidence: 0.8, sequence: 102, chapter: 2, time: "", location: "the old Battery"});
CREATE (e103:Event {id: "event/0659489e", name: "Magwitch mentions the young man", eventType: "perception/recognition", actionType: "mention", source_quote: "There’s a young man hid with me, in comparison with which young man I am a Angel.", causeWeight: 1.0, confidence: 0.8, sequence: 103, chapter: 2, time: "", location: "the old Battery"});
CREATE (e104:Event {id: "event/1a0941d9", name: "Magwitch states the young man hears him", eventType: "perception/recognition", actionType: "state", source_quote: "That young man hears the words I speak.", causeWeight: 1.0, confidence: 0.8, sequence: 104, chapter: 2, time: "", location: "the old Battery"});
CREATE (e105:Event {id: "event/cb7d4760", name: "The young man has a secret way of getting at a boy", eventType: "perception/recognition", actionType: "recognize", source_quote: "That young man has a secret way pecooliar to himself, of getting at a boy, and at his heart, and at his liver.", causeWeight: 1.0, confidence: 0.7, sequence: 105, chapter: 2, time: "", location: "the old Battery"});
CREATE (e106:Event {id: "event/51d9c03e", name: "A boy attempts to hide from the young man", eventType: "action", actionType: "attempt", source_quote: "It is in vain for a boy to attempt to hide himself from that young man.", causeWeight: 1.0, confidence: 0.6, sequence: 106, chapter: 2, time: "", location: "the old Battery"});
CREATE (e107:Event {id: "event/4a27d972", name: "The boy locks his door", eventType: "action", actionType: "lock", source_quote: "A boy may lock his door.", causeWeight: 1.0, confidence: 0.6, sequence: 107, chapter: 2, time: "", location: "the old Battery"});
CREATE (e108:Event {id: "event/8003d854", name: "The boy is warm in bed", eventType: "state change", actionType: "be", source_quote: "may be warm in bed.", causeWeight: 1.0, confidence: 0.7, sequence: 108, chapter: 2, time: "", location: "the old Battery"});
CREATE (e109:Event {id: "event/0f3c95e7", name: "The boy tucks himself up", eventType: "action", actionType: "tuck", source_quote: "may tuck himself up.", causeWeight: 1.0, confidence: 0.7, sequence: 109, chapter: 2, time: "", location: "the old Battery"});
CREATE (e110:Event {id: "event/395ac3e5", name: "The boy draws the clothes over his head", eventType: "action", actionType: "draw", source_quote: "may draw the clothes over his head.", causeWeight: 1.0, confidence: 0.7, sequence: 110, chapter: 2, time: "", location: "the old Battery"});
CREATE (e111:Event {id: "event/1bcb3259", name: "The boy thinks himself comfortable and safe", eventType: "reflection/emotion", actionType: "imagine", source_quote: "may think himself comfortable and safe.", causeWeight: 1.0, confidence: 0.6, sequence: 111, chapter: 2, time: "", location: "the old Battery"});
CREATE (e112:Event {id: "event/75089745", name: "The young man softly creeps towards the boy", eventType: "action", actionType: "creep", source_quote: "that young man will softly creep and creep his way to him.", causeWeight: 1.0, confidence: 0.8, sequence: 112, chapter: 2, time: "", location: "the old Battery"});
CREATE (e113:Event {id: "event/59347b38", name: "The young man tears the boy open", eventType: "action", actionType: "tear", source_quote: "and tear him open.", causeWeight: 1.0, confidence: 0.8, sequence: 113, chapter: 2, time: "", location: "the old Battery"});
CREATE (e114:Event {id: "event/14d5c2f2", name: "The speaker is keeping the young man from harming the boy", eventType: "assistance/exchange", actionType: "keep", source_quote: "I am a keeping that young man from harming of you at the present moment.", causeWeight: 1.0, confidence: 0.8, sequence: 114, chapter: 2, time: "at the present moment", location: "the old Battery"});
CREATE (e115:Event {id: "event/620d84b3", name: "The speaker finds it hard to hold the young man off", eventType: "reflection/emotion", actionType: "perceive", source_quote: "I find it wery hard to hold that young man off of your inside.", causeWeight: 1.0, confidence: 0.7, sequence: 115, chapter: 2, time: "", location: "the old Battery"});
CREATE (e116:Event {id: "event/533d6544", name: "The speaker expresses difficulty in holding the young man off", eventType: "reflection/emotion", actionType: "express", source_quote: "with great difficulty.", causeWeight: 1.0, confidence: 0.6, sequence: 116, chapter: 2, time: "", location: "the old Battery"});
CREATE (e117:Event {id: "event/6b11a7f6", name: "The speaker asks the boy what he says", eventType: "encounter/dialogue", actionType: "demand", source_quote: "Now, what do you say?", causeWeight: 1.0, confidence: 0.7, sequence: 117, chapter: 2, time: "", location: "the old Battery"});
CREATE (e118:Event {id: "event/b9fe52b2", name: "Promise to retrieve the file", eventType: "assistance/exchange", actionType: "promise", source_quote: "I said that I would get him the file", causeWeight: 1.0, confidence: 0.8, sequence: 118, chapter: 2, time: "early in the morning", location: "the Battery"});
CREATE (e119:Event {id: "event/dae714a2", name: "Promise to bring broken bits of food", eventType: "assistance/exchange", actionType: "promise", source_quote: "I would get him what broken bits of food I could", causeWeight: 1.0, confidence: 0.8, sequence: 119, chapter: 2, time: "early in the morning", location: "the Battery"});
CREATE (e120:Event {id: "event/b291bca5", name: "Decision to visit Magwitch", eventType: "movement/departure", actionType: "decide", source_quote: "I would come to him at the Battery, early in the morning", causeWeight: 1.0, confidence: 0.8, sequence: 120, chapter: 2, time: "early in the morning", location: "the Battery"});
CREATE (e121:Event {id: "event/b934ca9e", name: "Man threatens with curse", eventType: "encounter/dialogue", actionType: "say", source_quote: "“Say Lord strike you dead if you don’t!” said the man.", causeWeight: 1.0, confidence: 0.7, sequence: 121, chapter: 2, time: "", location: "the Battery"});
CREATE (e122:Event {id: "event/f6300930", name: "Pip is reminded of his undertaking", eventType: "reflection/emotion", actionType: "remember", source_quote: "you remember what you’ve undertook", causeWeight: 1.0, confidence: 0.7, sequence: 122, chapter: 2, time: "", location: "the Battery"});
CREATE (e123:Event {id: "event/e315774a", name: "Pip is reminded of the young man", eventType: "reflection/emotion", actionType: "remember", source_quote: "you remember that young man", causeWeight: 1.0, confidence: 0.7, sequence: 123, chapter: 2, time: "", location: "the Battery"});
CREATE (e124:Event {id: "event/92bd8d2f", name: "Pip is instructed to go home", eventType: "encounter/dialogue", actionType: "instruct", source_quote: "you get home!", causeWeight: 1.0, confidence: 0.8, sequence: 124, chapter: 2, time: "", location: "the Battery"});
CREATE (e125:Event {id: "event/1c7b5f71", name: "Pip expresses a wish", eventType: "reflection/emotion", actionType: "wish", source_quote: "I wish I was a frog. Or a eel!", causeWeight: 1.0, confidence: 0.9, sequence: 125, chapter: 2, time: "", location: "the Battery"});
CREATE (e126:Event {id: "event/315c8c62", name: "Pip glances around", eventType: "perception/recognition", actionType: "glance", source_quote: "said he, glancing about him over the cold wet flat.", causeWeight: 1.0, confidence: 0.8, sequence: 126, chapter: 2, time: "", location: "cold wet flat"});
CREATE (e127:Event {id: "event/f9273399", name: "Pip hugs his body", eventType: "action", actionType: "hug", source_quote: "he hugged his shuddering body in both his arms", causeWeight: 1.0, confidence: 0.9, sequence: 127, chapter: 2, time: "", location: "cold wet flat"});
CREATE (e128:Event {id: "event/0568dc94", name: "Pip limps towards the church wall", eventType: "movement/departure", actionType: "limp", source_quote: "and limped towards the low church wall", causeWeight: 1.0, confidence: 0.8, sequence: 128, chapter: 2, time: "", location: "low church wall"});
CREATE (e129:Event {id: "event/8b80a34d", name: "Pip perceives the man picking his way", eventType: "perception/recognition", actionType: "perceive", source_quote: "As I saw him go, picking his way among the nettles", causeWeight: 1.0, confidence: 0.7, sequence: 129, chapter: 2, time: "", location: "low church wall"});
CREATE (e130:Event {id: "event/3e20d908", name: "Pip imagines the man eluding the dead", eventType: "reflection/emotion", actionType: "imagine", source_quote: "he looked in my young eyes as if he were eluding the hands of the dead people", causeWeight: 1.0, confidence: 0.8, sequence: 130, chapter: 2, time: "", location: "low church wall"});
CREATE (e131:Event {id: "event/e584b274", name: "Pip perceives the dead people reaching for the man", eventType: "perception/recognition", actionType: "perceive", source_quote: "stretching up cautiously out of their graves, to get a twist upon his ankle and pull him in", causeWeight: 1.0, confidence: 0.8, sequence: 131, chapter: 2, time: "", location: "low church wall"});
CREATE (e132:Event {id: "event/a7ece1ff", name: "Pip sees the man turning", eventType: "perception/recognition", actionType: "perceive", source_quote: "When I saw him turning, I set my face towards home", causeWeight: 1.0, confidence: 0.9, sequence: 132, chapter: 2, time: "", location: "low church wall"});
CREATE (e133:Event {id: "event/bfd206ef", name: "Pip sets his face towards home", eventType: "action", actionType: "set", source_quote: "I set my face towards home", causeWeight: 1.0, confidence: 0.8, sequence: 133, chapter: 2, time: "", location: "low church wall"});
CREATE (e134:Event {id: "event/8cc974c6", name: "Pip makes the best use of his legs", eventType: "action", actionType: "make use", source_quote: "and made the best use of my legs", causeWeight: 1.0, confidence: 0.8, sequence: 134, chapter: 2, time: "", location: "low church wall"});
CREATE (e135:Event {id: "event/b6a0e94f", name: "Pip looks over his shoulder", eventType: "action", actionType: "watch", source_quote: "But presently I looked over my shoulder", causeWeight: 1.0, confidence: 0.7, sequence: 135, chapter: 2, time: "", location: "low church wall"});
CREATE (e136:Event {id: "event/5f12fee2", name: "Pip sees the man going towards the river", eventType: "perception/recognition", actionType: "perceive", source_quote: "and saw him going on again towards the river", causeWeight: 1.0, confidence: 0.9, sequence: 136, chapter: 2, time: "", location: "river"});
CREATE (e137:Event {id: "event/70d06578", name: "The man hugs himself in both arms", eventType: "action", actionType: "hug", source_quote: "still hugging himself in both arms", causeWeight: 1.0, confidence: 0.8, sequence: 137, chapter: 2, time: "", location: "river"});
CREATE (e138:Event {id: "event/43e60f75", name: "The man picks his way among the stones", eventType: "action", actionType: "pick", source_quote: "picking his way with his sore feet among the great stones", causeWeight: 1.0, confidence: 0.8, sequence: 138, chapter: 2, time: "", location: "marshes"});
CREATE (e139:Event {id: "event/ebf9eac3", name: "Pip stops to look", eventType: "movement/departure", actionType: "stop", source_quote: "as I stopped to look after him", causeWeight: 1.0, confidence: 0.9, sequence: 139, chapter: 2, time: "", location: "marshes"});
CREATE (e140:Event {id: "event/868c6b7c", name: "Pip perceives the marshes", eventType: "perception/recognition", actionType: "perceive", source_quote: "The marshes were just a long black horizontal line then", causeWeight: 1.0, confidence: 0.8, sequence: 140, chapter: 2, time: "", location: "the marshes"});
CREATE (e141:Event {id: "event/d533f501", name: "Pip perceives the river", eventType: "perception/recognition", actionType: "perceive", source_quote: "and the river was just another horizontal line", causeWeight: 1.0, confidence: 0.8, sequence: 141, chapter: 2, time: "", location: "the river"});
CREATE (e142:Event {id: "event/d3af896c", name: "Pip perceives the sky", eventType: "perception/recognition", actionType: "perceive", source_quote: "and the sky was just a row of long angry red lines and dense black lines intermixed", causeWeight: 1.0, confidence: 0.8, sequence: 142, chapter: 2, time: "", location: "the sky"});
CREATE (e143:Event {id: "event/d0077e45", name: "Pip perceives the beacon", eventType: "perception/recognition", actionType: "make out", source_quote: "I could faintly make out the only two black things in all the prospect that seemed to be standing upright; one of these was the beacon by which the sailors steered.", causeWeight: 1.0, confidence: 0.8, sequence: 143, chapter: 2, time: "", location: "river"});
CREATE (e144:Event {id: "event/4744321f", name: "Pip perceives the gibbet", eventType: "perception/recognition", actionType: "make out", source_quote: "the other, a gibbet, with some chains hanging to it which had once held a pirate.", causeWeight: 1.0, confidence: 0.8, sequence: 144, chapter: 2, time: "", location: "river"});
CREATE (e145:Event {id: "event/c9c5ab1f", name: "The man limps towards the gibbet", eventType: "movement/departure", actionType: "limp", source_quote: "The man was limping on towards this latter.", causeWeight: 1.0, confidence: 0.7, sequence: 145, chapter: 2, time: "", location: "river"});
CREATE (e146:Event {id: "event/39ed8065", name: "Pip reflects on the man as a pirate", eventType: "reflection/emotion", actionType: "imagine", source_quote: "as if he were the pirate come to life, and come down, and going back to hook himself up again.", causeWeight: 1.0, confidence: 0.8, sequence: 146, chapter: 2, time: "", location: "river"});
CREATE (e147:Event {id: "event/c0e471b5", name: "Pip feels a terrible turn", eventType: "reflection/emotion", actionType: "feel", source_quote: "It gave me a terrible turn when I thought so;", causeWeight: 1.0, confidence: 0.8, sequence: 147, chapter: 2, time: "", location: "river"});
CREATE (e148:Event {id: "event/a5638b9d", name: "Pip perceives cattle lifting their heads", eventType: "perception/recognition", actionType: "perceive", source_quote: "as I saw the cattle lifting their heads to gaze after him,", causeWeight: 1.0, confidence: 0.7, sequence: 148, chapter: 2, time: "", location: "river"});
CREATE (e149:Event {id: "event/8d02e71c", name: "Pip wonders about the cattle's thoughts", eventType: "reflection/emotion", actionType: "wonder", source_quote: "I wondered whether they thought so too.", causeWeight: 1.0, confidence: 0.6, sequence: 149, chapter: 2, time: "", location: "river"});
CREATE (e150:Event {id: "event/19dcf0b9", name: "Pip looks around for the young man", eventType: "action", actionType: "watch", source_quote: "I looked all round for the horrible young man,", causeWeight: 1.0, confidence: 0.8, sequence: 150, chapter: 2, time: "", location: "river"});
CREATE (e151:Event {id: "event/635a3378", name: "Pip sees no signs of the young man", eventType: "perception/recognition", actionType: "perceive", source_quote: "and could see no signs of him.", causeWeight: 1.0, confidence: 0.5, sequence: 151, chapter: 2, time: "", location: "river"});
CREATE (e152:Event {id: "event/6e24dea5", name: "Pip feels frightened again", eventType: "reflection/emotion", actionType: "feel", source_quote: "But now I was frightened again,", causeWeight: 1.0, confidence: 0.9, sequence: 152, chapter: 2, time: "", location: "river"});
CREATE (e153:Event {id: "event/cab104f0", name: "Pip runs home", eventType: "movement/departure", actionType: "run", source_quote: "and ran home without stopping.", causeWeight: 1.0, confidence: 0.9, sequence: 153, chapter: 2, time: "", location: "river"});

